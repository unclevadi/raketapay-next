# Публичный URL сайта (canonical, Open Graph, sitemap, robots).
# Без слэша в конце, например: https://raketapay.example
NEXT_PUBLIC_SITE_URL=https://example.com

# Флаг: показывать MAX рядом с Telegram (true/false).
# Если false - UI скрывает MAX, но код/ссылки остаются.
NEXT_PUBLIC_ENABLE_MAX=false

# Ссылка на профиль/чат MAX (формат обычно https://max.ru/u/...)
# Используется как кнопка MAX рядом с Telegram.
NEXT_PUBLIC_MAX_URL=

# Supabase (для хранения ответов опроса)
SUPABASE_URL=https://rteipdvmzxoioibjxttd.supabase.co
# Вставь service_role key из Project Settings -> API (НЕ публичный, только для сервера)
SUPABASE_SERVICE_ROLE_KEY=

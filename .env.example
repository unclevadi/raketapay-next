# Публичный URL сайта (canonical, Open Graph, sitemap, robots).
# Без слэша в конце, например: https://raketapay.example
NEXT_PUBLIC_SITE_URL=https://example.com

# Флаг: показывать MAX рядом с Telegram (true/false).
# Если false - UI скрывает MAX, но код/ссылки остаются.
NEXT_PUBLIC_ENABLE_MAX=false

# CRM (/crm): только при true. Иначе middleware редиректит на главную (URL не светим в меню).
NEXT_PUBLIC_ENABLE_CRM=false

# Тестовый вход: логин s21 → email s21@crm.raketapay.internal, пароль s21pay.
# Создать пользователя и crm_staff: npm run crm:bootstrap-user (нужен SUPABASE_SERVICE_ROLE_KEY).

# Ссылка на профиль/чат MAX (формат обычно https://max.ru/u/...)
# Используется как кнопка MAX рядом с Telegram.
NEXT_PUBLIC_MAX_URL=

# Supabase (сервер: опрос, server actions; НЕ светить в браузер)
SUPABASE_URL=https://rteipdvmzxoioibjxttd.supabase.co
# Вставь service_role key из Project Settings -> API (НЕ публичный, только для сервера)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase — публичные ключи для CRM в браузере (anon + RLS; только строки crm_staff видят данные)
NEXT_PUBLIC_SUPABASE_URL=https://rteipdvmzxoioibjxttd.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase: что сделать один раз (без CLI, если так проще) ---
# 1) SQL Editor → по очереди выполнить файлы:
#    supabase/migrations/20260328120000_crm_mvp.sql
#    supabase/migrations/20260328120001_crm_catalog_seed.sql
# 2) Authentication → создать пользователя (email) для первого сотрудника.
# 3) SQL Editor → подставить его uuid из auth.users:
#    insert into public.crm_staff (user_id, email) values ('<uuid>', 'ops@...');
# Дальше этот пользователь при логине через anon-клиент пройдёт RLS на crm_*.
